{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/sanger-tol/readmapping/main/assets/schema_input.json",
    "title": "sanger-tol/readmapping pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "specimen": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "specimen must be provided and cannot contain spaces",
                "meta": ["specimen"]
            },
            "run_accession": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "run_accession must be provided and cannot contain spaces",
                "meta": ["run_accession"]
            },
            "datatype": {
                "type": "string",
                "enum": ["hic", "illumina", "pacbio", "pacbio_clr", "ont"],
                "errorMessage": "Datatype must be one of: hic, illumina, pacbio, pacbio_clr, ont",
                "meta": ["datatype"]
            },
            "datafile": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(bam|cram|fa|fa.gz|fasta|fasta.gz|fq|fq.gz|fastq|fastq.gz)$",
                "errorMessage": "Data file for reads cannot contain spaces and must be BAM/CRAM/FASTQ/FASTA"
            },
            "library": {
                "type": "string",
                "pattern": "^\\S*$",
                "errorMessage": "Library information cannot contain spaces",
                "default": "",
                "meta": ["library"]
            },
            "barcode": {
                "type": "string",
                "pattern": "^\\S*$",
                "errorMessage": "Sample barcode cannot contain spaces",
                "default": "",
                "meta": ["barcode"]
            }
        },
        "required": ["specimen", "run_accession", "datatype", "datafile"]
    },
    "uniqueEntries": ["run_accession"]
}
