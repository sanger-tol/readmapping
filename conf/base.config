/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    sanger-tol/readmapping Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 5
    maxErrors     = '-1'

    // In this configuration file, we give little resources by default and
    // explicitly bump them up for some processes.
    // All rules should still increase resources every attempt to allow the
    // pipeline to self-heal from MEMLIMIT/RUNLIMIT.

    // Default
    cpus   = { 1 * task.attempt }
    memory = { 50.MB * task.attempt }
    time   = { 30.min * task.attempt }

    withName: 'SAMTOOLS_(CONVERT)' {
        time   = { 1.hour * task.attempt }
    }

    withName: 'SAMTOOLS_(STATS)' {
        // Actually less than 1 hour for PacBio HiFi data, but confirmed 3 hours for Hi-C
        time   = { 4.hour * task.attempt }
    }

    withName: 'SAMTOOLS_(COLLATETOFASTA|COLLATETOFASTQ|FILTERTOFASTQ|FIXMATE|FLAGSTAT|MARKDUP|MERGE|VIEW)' {
        time   = { 8.hour * task.attempt }
    }

    // We don't know how long it takes, so let's start with 8 hours
    withName: 'SEQKIT_FQ2FA' {
        time   = { 8.hour * task.attempt }
    }

    withName: 'SAMTOOLS_(FLAGSTAT|IDXSTATS)' {
        memory = { 250.MB  * task.attempt }
    }

    withName: 'SAMTOOLS_(STATS|VIEW)' {
        memory = { ((meta.datatype == "pacbio_clr" || meta.datatype == "ont") ? 2.GB : 1.GB) * task.attempt }
    }

    // minimum 1GB memory
    withName: 'BBMAP_FILTERBYNAME' {
        memory = { 1.GB * task.attempt }
    }

    withName: 'SAMTOOLS_COLLATETOFASTA' {
        cpus   = { log_increase_cpus(4, 2*task.attempt, 1, 2) }
        memory = { 1.GB  * Math.ceil( meta.read_count / 1000000 ) * task.attempt }
    }

    withName: 'SAMTOOLS_COLLATETOFASTQ' {
        cpus   = { log_increase_cpus(4, 2*task.attempt, 1, 2) }
        memory = { 250.MB + 1.GB  * Math.ceil( meta.read_count / 100000000 ) * task.attempt }
    }

    withName: 'SAMTOOLS_SORMADUP' {
        cpus   = { log_increase_cpus(2, 6*task.attempt, 1, 2) }
        memory = { 4.GB + 850.MB * log_increase_cpus(2, 6*task.attempt, 1, 2) * task.attempt + 0.6.GB * Math.ceil( meta.read_count / 100000000 ) }
        time   = { 2.h * Math.ceil( meta.read_count / 100000000 ) * task.attempt / log_increase_cpus(2, 6*task.attempt, 1, 2) }
    }

    withName: SAMTOOLS_INDEX {
        cpus   = { log_increase_cpus(2, 6*task.attempt, 1, 2) }
        memory = { 4.GB + 850.MB * log_increase_cpus(2, 6*task.attempt, 1, 2) * task.attempt + 0.6.GB * Math.ceil( meta.read_count / 100000000 ) }
        time   = { 2.h * Math.ceil( meta.read_count / 100000000 ) * task.attempt / log_increase_cpus(2, 6*task.attempt, 1, 2) }
    }

    withName: SAMTOOLS_ADDREPLACERG {
        cpus   = { log_increase_cpus(2, 6*task.attempt, 1, 2) }
        memory = { 4.GB + 850.MB * log_increase_cpus(2, 6*task.attempt, 1, 2) * task.attempt + 0.6.GB * Math.ceil( meta.read_count / 100000000 ) }
        time   = { 2.h * Math.ceil( meta.read_count / 100000000 ) * task.attempt / log_increase_cpus(2, 6*task.attempt, 1, 2) }
    }

    withName: BLAST_BLASTN {
        time   = {          2.hour  * Math.ceil( meta.read_count / 1000000 ) * task.attempt }
        memory = { 100.MB + 20.MB   * Math.ceil( meta.read_count / 1000000 ) * task.attempt }
        // The tool never seems to use more than 1 core even when given multiple. Sticking to 1 (the default)
    }

    withName: BWAMEM2_INDEX {
        memory = { 24.GB  * Math.ceil( meta.genome_size / 1000000000 ) * task.attempt }
        time   = { 30.min * Math.ceil( meta.genome_size / 1000000000 ) * task.attempt }
        // Not multithreaded
    }

    withName: BWAMEM2_MEM {
        // Corresponds to 12 threads as the minimum, 24 threads if 3 billion reads
        cpus   = { log_increase_cpus(6, 6*task.attempt, meta.read_count/1000000000, 2) }
        // Runtime for 1 billion reads on 12 threads is a function of the logarithm of the genome size
        // Runtime is considered proportional to the number of reads and inversely to number of threads
        time   = { 3.h * task.attempt *  Math.ceil(positive_log(meta2.genome_size/100000, 10)) * Math.ceil(meta.read_count/1000000000) * 12 / log_increase_cpus(6, 6*task.attempt, meta.read_count/1000000000, 2) }
        // Base RAM usage is about 6 times the genome size.
        // Each thread takes an additional 800 MB RAM for bwa-mem2 and 800 MB for samtools sort
        memory = { 8.GB + 6.GB * Math.ceil(meta2.genome_size / 1000000000) + 1600.MB * task.attempt * log_increase_cpus(6, 6*task.attempt, meta.read_count/1000000000, 2) }
    }

    withName: '.*:ALIGN_HIFI:MINIMAP2_ALIGN' {
        cpus   = { log_increase_cpus(4, 2*task.attempt, meta.read_count/1000000, 2) }
        memory = { 800.MB * log_increase_cpus(4, 2*task.attempt, meta.read_count/1000000, 2) + 14.GB * Math.ceil( Math.pow(meta2.genome_size / 1000000000, 0.6)) * task.attempt }
        time   = {        3.h  * Math.ceil( meta.read_count   / 1000000   ) * task.attempt }
    }

    // Extrapolated from the HIFI settings on the basis of 1 ONT alignment. CLR assumed to behave the same way as ONT
    withName: '.*:ALIGN_(CLR|ONT):MINIMAP2_ALIGN' {
        cpus   = { log_increase_cpus(4, 2*task.attempt, meta.read_count/1000000, 2) }
        memory = { 800.MB * log_increase_cpus(4, 2*task.attempt, meta.read_count/1000000, 2) + 30.GB * Math.ceil( Math.pow(meta2.genome_size / 1000000000, 0.6)) * task.attempt }
        time   = {        1.h  * Math.ceil( meta.read_count   / 1000000   ) * task.attempt }
    }

    withName: CRAM_FILTER_MINIMAP2_FILTER5END_FIXMATE_SORT {
        time    = { 16.h  * task.attempt }
        cpus    = { 16       * 1                                                             }
        memory  = { 1.GB     * ( reference.size() < 2e9 ? 50 : Math.ceil( ( reference.size() / 1e+9 ) * 20 ) * Math.ceil( task.attempt * 1 ) )  }
    }

    withName: CRAM_FILTER_ALIGN_BWAMEM2_FIXMATE_SORT {
        time    = { 16.h  * task.attempt }
        cpus    = { 16       * 1                                                  }
        memory  = { 1.GB     * ( reference.size() < 2e9 ? 50 : Math.ceil( ( reference.size() / 1e+9 ) * 20 ) * Math.ceil( task.attempt * 1 ) )  }
    }

    withName: MINIMAP2_INDEX {
        cpus    = { 2    * task.attempt }
        memory  = { 1.GB * Math.ceil( 30 * fasta.size() / 1e+9 ) * task.attempt }
    }

    withName: GENERATE_CRAM_CSV {
        cpus    = { 4    * task.attempt }
        memory  = { 16.GB * task.attempt }
    }

    withName: CRUMBLE {
        // Most genomes seem happy with 1 GB, but some need a bit more, and others a lot more.
        // There is a weak, but existing, correlation between memory usage and the number of reads.
        // The formula below is a quadratic growth based on the attempt number.
        memory = { task.attempt * (task.attempt + 1) * 512.MB * Math.ceil( meta.read_count / 1000000000 ) }
        // 100k reads per hour for PacBio, 50m for HiC
        time   = { 1.h  * Math.ceil( meta.read_count / (meta.datatype == "pacbio" ? 100000 : 50000000)) * task.attempt }
    }
}
